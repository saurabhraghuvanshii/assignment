DATABASE_URL="postgresql://assistant:assistant123@localhost:5432/proactive_assistant?schema=public"

# Scraper configuration
# Set to "false" to disable real scrapers and use only simulated data
SCRAPER_ENABLED=true

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Encryption key for storing integration cookies securely (32+ bytes, or base64 for 32 bytes)
APP_ENCRYPTION_KEY=

# Uber OAuth (optional for ride-history import)
UBER_CLIENT_ID=
UBER_CLIENT_SECRET=
UBER_REDIRECT_URI=http://localhost:3000/api/integrations/uber/oauth/callback
UBER_AUTH_BASE=https://login.uber.com
UBER_OAUTH_SCOPE=profile history
# Optional overrides for OAuth history fetch
UBER_API_BASE=https://api.uber.com
UBER_TRIPS_ENDPOINT=/v1.2/history
